{
  "name": "react-spotify-embed",
  "description": "A simple React component for embedding a Spotify song or album preview.",
  "version": "3.0.1",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ctjlewis/react-spotify-embed"
  },
  "type": "module",
  "platform": "browser",
  "module": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./*": "./dist/components/*/index.js",
    "./styles": "./dist/bundle.css",
    "./styles/*": "./dist/components/*/index.css"
  },
  "types": "dist/index.d.ts",
  "style": "dist/bundle.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "types": "tsc src/index.ts -d --emitDeclarationOnly --outDir dist --jsx react-jsx",
    "export": "bun run clean && bun run types && bun build src/index.ts --production --target=browser --packages=external -e react -e react-dom --outdir dist",
    "dev": "next dev",
    "build": "bun run export && next build",
    "start": "next start",
    "lint": "next lint --fix",
    "test": "bun test",
    "prepublishOnly": "bun run export"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "cssnano": "^5.1.15",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.5",
    "next": "^15.5.5",
    "postcss": "^8.5.6",
    "postcss-import": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "spotify",
    "embed",
    "nextjs"
  ],
  "engines": {
    "node": ">=18"
  }
}
